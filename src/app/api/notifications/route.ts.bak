import { NextRequest, NextResponse } from 'next/server'
import { getCurrentUser } from '@/lib/auth'
import { db } from '@/lib/db'

export async function GET(request: NextRequest) {
  try {
    const user = await getCurrentUser()

    if (!user) {
      return NextResponse.json({ error: 'غير مصرح' }, { status: 401 })
    }

    const notifications: any[] = []

    // Formatter for time ago
    const getTimeAgo = (date: Date) => {
      const now = new Date()
      const diff = now.getTime() - date.getTime()
      const seconds = Math.floor(diff / 1000)
      const minutes = Math.floor(seconds / 60)
      const hours = Math.floor(minutes / 60)
      const days = Math.floor(hours / 24)

      if (days > 0) {
        return `منذ ${days} ${days === 1 ? 'يوم' : 'أيام'}`
      } else if (hours > 0) {
        return `منذ ${hours} ${hours === 1 ? 'ساعة' : 'ساعات'}`
      } else if (minutes > 0) {
        return `منذ ${minutes} ${minutes === 1 ? 'دقيقة' : 'دقائق'}`
      } else {
        return 'الآن'
      }
    }

    if (user.role === 'PATIENT') {
      // Get patient applications
      const applications = await db.application.findMany({
        where: {
          patientId: user.id
        },
        include: {
          post: {
            select: {
              id: true,
              title: true,
              student: {
                select: {
                  user: {
                    select: {
                      name: true
                    }
                  }
                }
              }
            }
          }
        },
        orderBy: {
          createdAt: 'desc'
        },
        take: 20
      })

      applications.forEach((app: any) => {
        let type = ''
        let title = ''
        let message = ''
        let actionLink = ''
        let actionText = ''

        if (app.status === 'ACCEPTED') {
          type = 'APPLICATION_ACCEPTED'
          title = 'تم قبول طلبك!'
          message = `د. ${app.post.student.user.name} قبلت طلبك لحالة "${app.post.title}"`
          actionLink = '/chat'
          actionText = 'المحادثات'
        } else if (app.status === 'REJECTED') {
          type = 'APPLICATION_REJECTED'
          title = 'تم رفض طلبك'
          message = `تم رفض طلبك لحالة "${app.post.title}"`
          actionLink = '/search'
          actionText = 'البحث عن حالات'
        } else {
          type = 'APPLICATION_SUBMITTED'
          title = 'تم تقديم طلبك'
          message = `تم تقديم طلبك على حالة "${app.post.title}" بانتظار المراجعة`
          actionLink = `/posts/${app.post.id}`
          actionText = 'عرض الحالة'
        }

        notifications.push({
          id: `app-${app.id}`,
          type,
          title,
          message,
          time: getTimeAgo(new Date(app.createdAt)),
          isRead: false, // TODO: Implement read status
          actionLink,
          actionText
        })
      })

      // Get patient appointments
      const appointments = await db.appointment.findMany({
        where: {
          case_: {
            application: {
              patientId: user.id
            }
          }
        },
        include: {
          case_: {
            include: {
              application: {
                include: {
                  post: {
                    select: {
                      title: true,
                      student: {
                        select: {
                          user: {
                            select: {
                              name: true
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        orderBy: {
          scheduledAt: 'desc'
        },
        take: 20
      })

      appointments.forEach((apt: any) => {
        const appointmentDate = new Date(apt.scheduledAt)
        const today = new Date()
        const isToday = appointmentDate.toDateString() === today.toDateString()

        let type = 'APPOINTMENT'
        let title = ''
        let message = ''
        let actionLink = '/appointments'
        let actionText = 'عرض المواعيد'

        if (apt.status === 'SCHEDULED' && !isToday) {
          title = 'تذكير بموعدك القادم'
          message = `لديك موعد مع د. ${apt.case_.application.post.student.user.name} لحالة "${apt.case_.application.post.title}" في ${appointmentDate.toLocaleDateString('ar-EG')}`
        } else if (apt.status === 'COMPLETED') {
          title = 'اكتمل موعدك'
          message = `تم الانتهاء من موعدك مع د. ${apt.case_.application.post.student.user.name} - "${apt.case_.application.post.title}"`
          actionLink = '/profile'
          actionText = 'عرض النشاط'
        } else if (apt.status === 'CANCELLED') {
          title = 'تم إلغاء الموعد'
          message = `تم إلغاء موعدك مع د. ${apt.case_.application.post.student.user.name}`
          actionLink = '/appointments'
          actionText = 'المواعيد'
        } else {
          title = 'موعدك اليوم'
          message = `موعدك مع د. ${apt.case_.application.post.student.user.name} في ${appointmentDate.toLocaleTimeString('ar-EG', { hour: '2-digit', minute: '2-digit' })} لحالة "${apt.case_.application.post.title}"`
        }

        notifications.push({
          id: `apt-${apt.id}`,
          type,
          title,
          message,
          time: getTimeAgo(new Date(apt.scheduledAt)),
          isRead: false,
          actionLink,
          actionText
        })
      })

      // Get patient ratings
      const ratings = await db.rating.findMany({
        where: {
          patientId: user.id
        },
        include: {
          case_: {
            include: {
              application: {
                include: {
                  post: {
                    select: {
                      title: true,
                      student: {
                        select: {
                          user: {
                            select: {
                              name: true
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        orderBy: {
          createdAt: 'desc'
        },
        take: 10
      })

      ratings.forEach((rating: any) => {
        notifications.push({
          id: `rating-${rating.id}`,
          type: 'RATING_RECEIVED',
          title: 'تم تسجيل تقييمك',
          message: `قيّمت تجربة علاجك مع د. ${rating.case_.application.post.student.user.name} بـ ${rating.overallRating} نجوم - "${rating.case_.application.post.title}"`
          time: getTimeAgo(new Date(rating.createdAt)),
          isRead: false,
          actionLink: '/profile',
          actionText: 'عرض النشاط'
        })
      })

    } else if (user.role === 'STUDENT') {
      // Get student record
      const student = await db.student.findFirst({
        where: { userId: user.id },
        select: { id: true }
      })

      if (student) {
        // Get new applications to student's posts
        const applications = await db.application.findMany({
          where: {
            post: {
              studentId: student.id
            },
            status: 'PENDING'
          },
          include: {
            post: {
              select: {
                id: true,
                title: true
              }
            },
            patient: {
              include: {
                user: {
                  select: {
                    name: true
                  }
                }
              }
            }
          }
        },
        orderBy: {
          createdAt: 'desc'
        },
        take: 20
        })

        applications.forEach((app: any) => {
          notifications.push({
            id: `app-${app.id}`,
            type: 'NEW_APPLICATION',
            title: 'طلب جديد!',
            message: `المريض ${app.patient.user.name} قدم على حالة "${app.post.title}" بانتظار مراجعتك`,
            time: getTimeAgo(new Date(app.createdAt)),
            isRead: false,
            actionLink: `/posts/${app.post.id}/applications`,
            actionText: 'عرض الطلبات'
          })
        })

        // Get appointments
        const appointments = await db.appointment.findMany({
          where: {
            case_: {
              application: {
                post: {
                  studentId: student.id
                }
              }
            }
          },
          include: {
            case_: {
              include: {
                application: {
                  include: {
                    patient: {
                      include: {
                        user: {
                          select: {
                            name: true
                          }
                        }
                      }
                    },
                    post: {
                      select: {
                        title: true
                      }
                    }
                  }
                }
              }
            }
          },
          orderBy: {
            scheduledAt: 'desc'
          },
          take: 20
        })

        appointments.forEach((apt: any) => {
          const appointmentDate = new Date(apt.scheduledAt)
          const today = new Date()
          const isToday = appointmentDate.toDateString() === today.toDateString()

          let type = 'APPOINTMENT'
          let title = ''
          let message = ''
          let actionLink = '/appointments'
          let actionText = 'عرض المواعيد'

          if (apt.status === 'SCHEDULED' && !isToday) {
            title = 'تذكير بموعدك القادم'
            message = `لديك موعد مع المريض ${apt.case_.application.patient.user.name} لحالة "${apt.case_.application.post.title}" في ${appointmentDate.toLocaleDateString('ar-EG')}`
          } else if (apt.status === 'COMPLETED') {
            title = 'اكتمل موعدك'
            message = `تم الانتهاء من موعدك مع المريض ${apt.case_.application.patient.user.name} - "${apt.case_.application.post.title}"`
            actionLink = '/profile'
            actionText = 'عرض النشاط'
          } else if (apt.status === 'CANCELLED') {
            title = 'تم إلغاء الموعد'
            message = `تم إلغاء موعدك مع ${apt.case_.application.patient.user.name}`
            actionLink = '/appointments'
            actionText = 'المواعيد'
          } else {
            title = 'موعدك اليوم'
            message = `موعدك مع المريض ${apt.case_.application.patient.user.name} في ${appointmentDate.toLocaleTimeString('ar-EG', { hour: '2-digit', minute: '2-digit' })} لحالة "${apt.case_.application.post.title}"`
          }

          notifications.push({
            id: `apt-${apt.id}`,
            type,
            title,
            message,
            time: getTimeAgo(new Date(apt.scheduledAt)),
            isRead: false,
            actionLink,
            actionText
          })
        })

        // Get ratings received
        const ratings = await db.rating.findMany({
          where: {
            studentId: student.id
          },
          include: {
            case_: {
              include: {
                application: {
                  include: {
                    patient: {
                      include: {
                        user: {
                          select: {
                            name: true
                          }
                        }
                      }
                    },
                    post: {
                      select: {
                        title: true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        orderBy: {
          createdAt: 'desc'
        },
        take: 10
        })

        ratings.forEach((rating: any) => {
          const studentName = rating.case_?.application?.post?.student?.user?.name || 'د. مجهول'
          const titleValue = rating.case_?.application?.post?.title || 'حالة علاج'
          const ratingValue = rating.overallRating || 5

          notifications.push({
            id: `rating-${rating.id}`,
            type: 'NEW_REVIEW',
            title: 'تقييم جديد!',
            message: `قيّمك المريض ${studentName} بـ ${ratingValue} نجوم - \"${titleValue}\"`,
            time: getTimeAgo(new Date(rating.createdAt)),
            isRead: false,
            actionLink: '/profile',
            actionText: 'عرض التقييم'
          })
        })
      }
    }

    // Sort all notifications by time (newest first)
    notifications.sort((a, b) => {
      const timeA = new Date(a.time.replace('منذ ', ''))
      // Simple sort - in production, store actual timestamps
      return b.id.localeCompare(a.id)
    })

    // Limit to 50 most recent notifications
    const recentNotifications = notifications.slice(0, 50)

    const unreadCount = recentNotifications.filter((n: any) => !n.isRead).length

    return NextResponse.json({
      success: true,
      notifications: recentNotifications,
      unreadCount,
      total: recentNotifications.length
    })

  } catch (error: any) {
    console.error('[Notifications API] Error:', error)
    return NextResponse.json(
      { error: 'فشل في جلب الإشعارات', details: error.message },
      { status: 500 }
    )
  }
}
