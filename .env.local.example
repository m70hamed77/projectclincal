# ============================================================
# LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# ============================================================
# هذا الملف للاستخدام المحلي فقط
# انسخ هذا الملف إلى .env.local وعدّل القيم حسب الحاجة

# ============================================================
# DATABASE - POSTGRESQL (NEON) - LOCAL & PRODUCTION
# ============================================================
# استخدم PostgreSQL من Neon للاستخدام المحلي والإنتاج
# احصل على رابط الاتصال من: https://neon.tech
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ============================================================
# EMAIL CONFIGURATION (اختياري - للتجربة المحلية)
# ============================================================
# يمكنك استخدام حساب Gmail للاختبار
# الحصول على App Password من: https://myaccount.google.com/apppasswords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password

# ============================================================
# NEXTAUTH CONFIGURATION (اختياري)
# ============================================================
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-key-here

# ============================================================
# APP SETTINGS
# ============================================================
NODE_ENV=development

# ============================================================
# NOTES:
# ============================================================
# 1. .env.local لن يُرفع إلى Git (محمي بواسطة .gitignore)
# 2. نفس DATABASE_URL ستُستخدم على Vercel (في Environment Variables)
# 3. Neon Database تعمل على السحابة، لذا البيانات مشتركة بين التطوير المحلي والإنتاج
# 4. لا حاجة لإنشاء قاعدة بيانات محلية (SQLite)
