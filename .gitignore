# See https://help.github.com/articles/ignoring-dependencies-and-dev-dependencies

# dependencies
/node_modules
/.pnp/
.pnp.js
package-lock.json
bun.lock

# testing
/coverage
coverage

# production
/build
/dist
build/
out/

# misc
.DS_Store
*.swo
*.swp
*.log
*.out
.vscode/
.idea

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env files - IMPORTANT: .env is protected!
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel
.vercel/build

# typescript
*.tsbuild
next-env.d.ts
*.tsbuildinfo
tsconfig.tsbuildinfo

# next.js
.next/

# Database files (local DB should NOT be committed)
db/*.db
db/*.db-shm
db/*.db-wal
*.db
*.db-shm
*.db-wal
/db/
custom.db

# Backup files
*.bak
*.backup
*.old
*.orig

# PID files (process IDs)
*.pid

# Manager/server files
manager.pid
server.pid
run-server.out

# Test scripts (local development)
test-*.js
test-*.ts
check-*.js
check-*.ts
temp-*.js
temp-*.ts

# Documentation files - only ignore specific ones, keep the rest
# *.md  # Commented out to keep documentation
!PROJECT_LINKS.md
!README.md

# turbo
.turbo

# uploads
public/uploads/*
!public/uploads/.gitkeep

# database (optional - uncomment if you don't want to commit db)
# db/*.db
# db/*.db-journal

# temporary files
upload/
*.tmp
*.temp

# OS files
Thumbs.db
.DS_Store
